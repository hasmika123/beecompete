# tools/seeding — S3 extraction pipeline env. Copy to .env (gitignored) and fill in.
# Secrets via env only — never commit real values.

# --- LLM provider (extraction step) ---
# When ANTHROPIC_API_KEY is unset, the tool runs OFFLINE: extraction falls back to the
# stub backend (reads a sibling <input>.expected.json fixture), so --dry-run works in CI.
ANTHROPIC_API_KEY=
# Model id (env-configured). If Anthropic retires the default, the tool fails with an explicit
# "set ANTHROPIC_MODEL" error — point this at any current model id.
ANTHROPIC_MODEL=claude-sonnet-5

# --- Import queue (submit step) ---
# Base URL of the BeeCompete API that owns POST /api/v1/admin/import-records.
# Use https for anything non-local — the admin token travels on every request (the tool warns
# loudly if it would send the token over plain http to a non-localhost host).
BEECOMPETE_API_BASE=http://localhost:8080
# Shared admin token — sent as the X-Admin-Token header. Same secret as apps/api ADMIN_API_TOKEN.
ADMIN_API_TOKEN=

# --- Fetch behaviour (optional overrides) ---
SEEDING_USER_AGENT=BeeCompeteSeedingBot/0.1 (+https://beecompete.com/about/crawler)
SEEDING_FETCH_TIMEOUT_MS=15000
