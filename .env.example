# Copy to .env and adjust. NEVER commit real secrets — .env is gitignored (secrets via
# environment only, CLAUDE.md). These defaults match infra/docker-compose.yml for local dev.

# --- Local Postgres (infra/docker-compose.yml) ---
POSTGRES_USER=beecompete
POSTGRES_PASSWORD=beecompete
POSTGRES_DB=beecompete
POSTGRES_PORT=5432

# --- Spring API datasource (the app uses the POOLED endpoint) ---
# Must be a JDBC URL (jdbc:postgresql://…). Locally this is the compose Postgres above;
# on Neon (prod/staging) use the -pooler host and append ?sslmode=require.
DATABASE_URL=jdbc:postgresql://localhost:5432/beecompete
DATABASE_USERNAME=beecompete
DATABASE_PASSWORD=beecompete

# --- Liquibase migrations (the DIRECT endpoint — never the pooler) ---
# Leave unset locally: Liquibase reuses the main datasource above. In prod/staging set
# these to the Neon DIRECT (non-pooler) URL so migrations bypass PgBouncer.
# DIRECT_URL=jdbc:postgresql://<direct-host>/beecompete?sslmode=require
# DIRECT_USERNAME=beecompete
# DIRECT_PASSWORD=

# --- Redis (cache + rate-limit counters only — nothing durable) ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Admin surface (R1-3) ---
# Shared secret for /api/v1/admin/** — the web BFF injects it as X-Admin-Token; the browser
# (behind Cloudflare Access) never sees it. Blank = all admin calls rejected (fail closed).
# Generate per environment: openssl rand -hex 32
ADMIN_API_TOKEN=

# --- Web canonical origin (R1-7) ---
# Absolute-URL base for metadata + schema.org JSON-LD. Runtime env (NOT NEXT_PUBLIC_* — the
# web image is built once and promoted, so it must vary per stack at runtime). Unset locally
# is fine: the code falls back to the prod apex; the deploy stacks set it in compose.
# SITE_URL=http://localhost:3000

# --- Search indexing gate (R1-10) ---
# OFF unless set to exactly "on". Minors-facing site: robots.txt serves Disallow:/ and every
# page emits noindex until this is flipped in the PROD runtime env at the R1-17 launch gate
# (legal pages live + COPPA sign-off). Staging must NEVER set this (it's a prod duplicate).
# SEARCH_INDEXING=on

# --- Observability: Sentry (F8) ---
# All blank locally = Sentry disabled (no noise). Set per environment in prod/staging.
# API (Spring): server DSN.
SENTRY_DSN=
# Web (Next): server DSN + PUBLIC (browser) DSN — usually the same project's DSN.
# NEXT_PUBLIC_* is exposed to the client, so only the DSN goes there (never a token).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=local
NEXT_PUBLIC_SENTRY_ENVIRONMENT=local
# Build-time source-map upload (CI/deploy only — never commit). When unset, upload is skipped.
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# --- Privacy-first analytics (R1-14) ---
# Cookieless; loaded on PUBLIC pages only (never /admin). Runtime env, NOT NEXT_PUBLIC_* — the web
# image is built once and promoted, so tokens must vary per stack at runtime; the (public) server
# layout reads these and hands them to the client. Blank = that analytics is off (local/CI clean).
# PostHog project API key (write-only; safe in the browser). Blank = PostHog off. ONE shared project
# serves prod + local dev (owner decision 2026-07-17); leave staging's key unset to avoid mixing.
# POSTHOG_KEY=
# PostHog ingestion host — defaults to the EU cloud (architecture §10). Override only for US cloud
# (https://us.i.posthog.com) or self-hosted.
# POSTHOG_HOST=https://eu.i.posthog.com
# Cloudflare Web Analytics: paste the beacon TOKEN from CF → Web Analytics → "Enable with JS Snippet
# installation" (just the token value in the snippet, not the whole snippet — our app injects the
# beacon). Blank = no CF beacon. Do NOT also enable CF "Automatic Setup" or pageviews double-count.
# (owner decision 2026-07-17: JS snippet chosen — CF automatic doesn't reliably inject on our SSR stack)
# CF_WEB_ANALYTICS_TOKEN=

# --- Listing-page email captures: Brevo (R1-15 digest · R1-15b follow + host) ---
# Server-only secret (the capture server actions call Brevo). Each capture is inert unless its
# list id is set → the form shows a friendly "opening soon" and stores nothing (local/CI/pre-launch
# stay side-effect-free). All framed for parents/educators/16+ with double opt-in (COPPA-safe).
# Brevo API key (Brevo → SMTP & API → API keys). NEVER expose to the browser / NEXT_PUBLIC_.
# BREVO_API_KEY=
# Contact list ids (Brevo → Contacts → Lists → each list's numeric id). Wire only the ones you use.
# BREVO_DIGEST_LIST_ID=
# BREVO_FOLLOW_LIST_ID=
# BREVO_HOST_LIST_ID=
# Optional but RECOMMENDED: double opt-in. A shared DOI template id (Brevo → Campaigns → Templates,
# a transactional "confirm your subscription" template) → subscribers must click a confirmation
# email before they're added to any list (consent record + deliverability). Blank = single opt-in.
# BREVO_DOI_TEMPLATE_ID=
# Where Brevo sends the subscriber after they confirm (defaults to the site root).
# BREVO_DOI_REDIRECT_URL=https://beecompete.com/
# Contact attributes to pre-create in Brevo (text): GRADE, INTEREST, STATE (digest) + COMPETITION
# (follow / host — the listing the visitor acted on). Brevo rejects contacts with unknown attributes.
# In-app feedback (R1-16) emails support@ via Brevo transactional mail (reuses BREVO_API_KEY). The
# "from" must be a VERIFIED sender/domain in Brevo, else the send fails. Defaults to no-reply@.
# BREVO_SENDER_EMAIL=no-reply@beecompete.com
# BREVO_SENDER_NAME=BeeCompete
